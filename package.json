{
  "name": "claude-monitor",
  "version": "0.1.3",
  "description": "Terminal-themed dashboard for monitoring Claude Code sessions",
  "author": "ayu5h-raj",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev",
    "dev:terminal": "npx tsx server.ts",
    "dev:desktop": "npx tsc -p electron/tsconfig.json && concurrently --kill-others -n server,electron -c green,blue \"npx tsx server.ts\" \"sleep 4 && npx electron .\"",
    "build": "next build",
    "build:desktop": "bash scripts/build-electron.sh",
    "start": "next start",
    "start:terminal": "node -r tsx/register server.ts",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "marked": "^17.0.5",
    "next": "16.2.1",
    "node-pty": "^1.2.0-beta.12",
    "openai": "^6.33.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ws": "^8.20.0",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/marked": "^5.0.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
